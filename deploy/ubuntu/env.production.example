NODE_ENV=production
HOST=127.0.0.1
PORT=3000

# Optional first-run bootstrap account. Remove after the first successful login if desired.
SYNCHRO_BOOTSTRAP_USER=admin
SYNCHRO_BOOTSTRAP_PASSWORD=change-me-now

# Python executable used by src/services/report-parser.js for PDF report parsing.
SYNCHRO_PYTHON_BIN=/opt/synchro/.venv/bin/python

# Required only if you want report digests / CSV mail sending from the admin UI.
SYNCHRO_GRAPH_TENANT_ID=
SYNCHRO_GRAPH_CLIENT_ID=
SYNCHRO_GRAPH_CLIENT_SECRET=
